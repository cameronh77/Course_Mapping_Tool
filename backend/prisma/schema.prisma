// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

generator studioClient {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BloomsLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYSE
  EVALUATE
  CREATE
}

enum PathwayType {
  CORE
  MAJOR
  MINOR
  SPECIALISATION
  ENTRY_POINT
}

model Course {
  courseId              String @id
  courseName            String
  courseDesc            String //A description of the course
  expectedDuration      Int //The expected duration of the course
  numberTeachingPeriods Int //How many teaching periods in a year

  unitsOffered     CourseUnit[]
  themes           CourseTheme[]
  learningOutcomes CourseLearningOutcome[]
  pathways         Pathway[]
  UnitRelationship UnitRelationship[]

  existingTagsUnit CourseUnitTags[]
  existingTags     Tag[]

  themeCategories  ThemeCategory[]
}

model Pathway {
  pathwayId   Int          @id @default(autoincrement())
  name        String
  type        PathwayType
  courseId    String

  course        Course         @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  courseUnits   CourseUnit[]
  relationships UnitRelationship[]
}

model Unit {
  unitId           String @id
  unitName         String
  unitDesc         String
  credits          Int
  semestersOffered Int[]

  courseUnits      CourseUnit[]
  themes           UnitTheme[]
  learningOutcomes UnitLearningOutcome[]
  relationships    UnitRelationship[]     @relation("UnitRelations")
  relatedTo        UnitRelationship[]     @relation("RelatedUnits")
  AssessmentULO    AssessmentULO[]
  Assessments      Assessment[]
  teachingActivities TeachingActivity[]

  existingTags      CourseUnitTags[]
}

model CourseUnit {
  id        Int     @id @default(autoincrement())
  courseId  String
  unitId    String
  pathwayId Int

  semester  Int
  year      Int
  elective  Boolean
  position  Json?
  color     String?

  course   Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [unitId], onDelete: Cascade)
  pathway  Pathway  @relation(fields: [pathwayId], references: [pathwayId], onDelete: Cascade)

  @@unique([courseId, unitId, pathwayId])
}

model Tag {
  tagId     Int   @id @default(autoincrement())
  tagName   String

  course    Course @relation(fields: [courseId], references: [courseId], onDelete:Cascade)
  courseId  String

  taggedUnits         CourseUnitTags[]
  categoryAssignments ThemeCategoryTag[]
}

model ThemeCategory {
  id          Int    @id @default(autoincrement())
  name        String
  indexLabel  String
  positionX   Float
  positionY   Float

  course      Course @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  courseId    String

  tags        ThemeCategoryTag[]
}

model ThemeCategoryTag {
  category    ThemeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  Int

  tag         Tag           @relation(fields: [tagId], references: [tagId], onDelete: Cascade)
  tagId       Int

  order       Int

  @@id([categoryId, tagId])
}

model CourseUnitTags {
  course    Course @relation(fields: [courseId], references: [courseId], onDelete:Cascade)
  courseId  String

  unit      Unit   @relation(fields: [unitId], references: [unitId], onDelete:Cascade)
  unitId    String

  tag       Tag    @relation(fields: [tagId], references: [tagId], onDelete:Cascade)
  tagId     Int

  @@id([courseId, unitId, tagId])
}

model Theme {
  themeId   Int    @id @default(autoincrement())
  themeName String

  courses CourseTheme[]
  units   UnitTheme[]
}

model CourseTheme {
  course   Course @relation(fields: [courseId], references: [courseId], onDelete:Cascade)
  courseId String

  theme   Theme @relation(fields: [themeId], references: [themeId], onDelete:Cascade)
  themeId Int

  @@id([courseId, themeId])
}

model UnitTheme {
  unit   Unit   @relation(fields: [unitId], references: [unitId], onDelete:Cascade)
  unitId String

  theme   Theme @relation(fields: [themeId], references: [themeId], onDelete:Cascade)
  themeId Int

  @@id([unitId, themeId])
}

model CourseLearningOutcome {
  cloId    Int    @id @default(autoincrement())
  cloDesc  String
  courseId String

  course  Course                @relation(fields: [courseId], references: [courseId], onDelete:Cascade)
  unitLos UnitLearningOutcome[]
}

model UnitLearningOutcome {
  uloId       Int          @id @default(autoincrement())
  uloDesc     String
  unitId      String
  cloId       Int?
  bloomsLevel BloomsLevel?
  position    Json?

  unit     Unit                   @relation(fields: [unitId], references: [unitId], onDelete:Cascade)
  courseLO CourseLearningOutcome? @relation(fields: [cloId], references: [cloId])

  assessments AssessmentULO[]
  teachingActivityLinks TeachingActivityULO[]
}

model Assessment {
  assessmentId Int      @id @default(autoincrement())
  assessmentName        String
  value                 Int
  hurdleReq             Int?
  dueWeek               Int[]
  assessmentConditions  String
  feedbackWeek          Int[]
  feedbackDetails       String[]

  assessmentDesc      String
  assessmentType      String
  unitId              String

  unitLos AssessmentULO[]
  teachingActivityLinks TeachingActivityAssessment[]

  position            Json?
  outgoingRelationships AssessmentRelationship[] @relation("AssessmentRelations")
  incomingRelationships AssessmentRelationship[] @relation("RelatedAssessments")

  unit                Unit  @relation(fields: [unitId], references:[unitId], onDelete:Cascade)
}

model AssessmentULO {
  assessment   Assessment @relation(fields: [assessmentId], references: [assessmentId])
  assessmentId Int

  unitLO UnitLearningOutcome @relation(fields: [uloId], references: [uloId])
  uloId  Int

  unit   Unit   @relation(fields: [unitId], references: [unitId])
  unitId String

  reversed Boolean @default(false)

  @@id([assessmentId, uloId, unitId])
}

model AssessmentRelationship {
  assessment      Assessment @relation("AssessmentRelations", fields: [assessmentId], references: [assessmentId], onDelete: Cascade)
  assessmentId    Int
  connectionType  String?

  related   Assessment @relation("RelatedAssessments", fields: [relatedId], references: [assessmentId], onDelete: Cascade)
  relatedId Int

  unitId    String?

  @@id([assessmentId, relatedId])
}

enum RelationshipType {
  PREREQUISITE
  COREQUISITE
  PROGRESSION
  CONNECTED
}

model UnitRelationship {
  id               Int              @id @default(autoincrement())
  unitId           String
  relatedId        String
  relationshipType RelationshipType
  courseId         String?
  pathwayId        Int?
  entryType        Int

  unit     Unit     @relation("UnitRelations", fields: [unitId], references: [unitId])
  related  Unit     @relation("RelatedUnits", fields: [relatedId], references: [unitId])
  course   Course?  @relation(fields: [courseId], references: [courseId])
  pathway  Pathway? @relation(fields: [pathwayId], references: [pathwayId])
}

model TeachingActivity {
  activityId   Int    @id @default(autoincrement())
  activityName String
  activityDesc String
  activityType String
  unitId       String
  position     Json?

  unit            Unit                           @relation(fields: [unitId], references: [unitId], onDelete: Cascade)
  assessmentLinks TeachingActivityAssessment[]
  uloLinks        TeachingActivityULO[]
  outgoingRelationships TeachingActivityRelationship[] @relation("TASourceRelations")
  incomingRelationships TeachingActivityRelationship[] @relation("TATargetRelations")
}

model TeachingActivityRelationship {
  source    TeachingActivity @relation("TASourceRelations", fields: [sourceId], references: [activityId], onDelete: Cascade)
  sourceId  Int

  target    TeachingActivity @relation("TATargetRelations", fields: [targetId], references: [activityId], onDelete: Cascade)
  targetId  Int

  unitId    String

  @@id([sourceId, targetId])
}

model TeachingActivityAssessment {
  activity     TeachingActivity @relation(fields: [activityId], references: [activityId], onDelete: Cascade)
  activityId   Int
  assessment   Assessment       @relation(fields: [assessmentId], references: [assessmentId], onDelete: Cascade)
  assessmentId Int
  unitId       String
  reversed     Boolean @default(false)

  @@id([activityId, assessmentId])
}

model TeachingActivityULO {
  activity   TeachingActivity    @relation(fields: [activityId], references: [activityId], onDelete: Cascade)
  activityId Int
  unitLO     UnitLearningOutcome @relation(fields: [uloId], references: [uloId], onDelete: Cascade)
  uloId      Int
  unitId     String
  reversed   Boolean @default(false)

  @@id([activityId, uloId])
}
